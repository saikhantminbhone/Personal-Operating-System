{
  "name": "saikhant-labs-os",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @saikhant-os/api exec prisma generate",
    "db:migrate": "pnpm --filter @saikhant-os/api exec prisma migrate dev",
    "db:migrate:prod": "pnpm --filter @saikhant-os/api exec prisma migrate deploy",
    "db:seed": "pnpm --filter @saikhant-os/api exec ts-node prisma/seed.ts",
    "db:reset": "pnpm --filter @saikhant-os/api exec prisma migrate reset",
    "db:studio": "pnpm --filter @saikhant-os/api exec prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.5",
    "@types/node": "^20.12.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
